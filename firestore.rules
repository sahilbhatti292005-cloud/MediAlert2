// ===============================================================
// Assumed Data Model (Simplified for Viva)
// ===============================================================
//
// Collection: medicines
// Fields:
//   - userId: string (matches auth.uid)
//   - name: string
//   - dosage: string
//   - time: string (HH:mm)
//   - createdAt: number
//
// ===============================================================

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    match /medicines/{medicineId} {
      // Allow read/write if user is logged in AND owns the document
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      
      allow create: if isAuthenticated() && 
                      request.resource.data.userId == request.auth.uid &&
                      request.resource.data.name is string &&
                      request.resource.data.dosage is string &&
                      request.resource.data.time is string;
                      
      allow update: if isAuthenticated() && 
                      resource.data.userId == request.auth.uid &&
                      request.resource.data.userId == resource.data.userId;
    }
    
    // Allow users to manage their own profile
    match /users/{userId} {
      allow read, write: if isAuthenticated() && request.auth.uid == userId;
    }
  }
}
