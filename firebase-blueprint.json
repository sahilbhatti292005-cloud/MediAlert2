{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "createdAt": { "type": "number", "description": "Timestamp when user was created" }
      },
      "required": ["name", "email"]
    },
    "Medicine": {
      "title": "Medicine",
      "description": "Medicine reminder details",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who owns this medicine" },
        "name": { "type": "string", "description": "Name of the medicine" },
        "dosage": { "type": "string", "description": "Dosage instructions" },
        "frequency": { "type": "string", "description": "Frequency of intake" },
        "times": { "type": "array", "items": { "type": "string" }, "description": "List of times (HH:mm) to take the medicine" },
        "startDate": { "type": "string", "description": "Start date in YYYY-MM-DD format" },
        "endDate": { "type": "string", "description": "Optional end date in YYYY-MM-DD format" },
        "notes": { "type": "string", "description": "Optional notes" },
        "createdAt": { "type": "number", "description": "Timestamp when medicine was created" }
      },
      "required": ["userId", "name", "dosage", "frequency", "times", "startDate", "createdAt"]
    },
    "MedicineLog": {
      "title": "MedicineLog",
      "description": "Log of medicine intake",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user" },
        "medicineId": { "type": "string", "description": "ID of the medicine" },
        "date": { "type": "string", "description": "Date of log (YYYY-MM-DD)" },
        "time": { "type": "string", "description": "Time of log (HH:mm)" },
        "status": { "type": "string", "enum": ["Pending", "Taken", "Missed", "Snoozed"], "description": "Status of the intake" },
        "timestamp": { "type": "number", "description": "Timestamp of the log" }
      },
      "required": ["userId", "medicineId", "date", "time", "status", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Individual user profiles"
    },
    "/medicines/{medicineId}": {
      "schema": "Medicine",
      "description": "Collection of medicines"
    },
    "/logs/{logId}": {
      "schema": "MedicineLog",
      "description": "Collection of medicine logs"
    }
  }
}
